# metiq .env example
#
# Quick start:
#   1) cp .env.example .env
#   2) Fill in METIQ_NOSTR_KEY + at least one LLM provider API key
#   3) docker compose up -d
#
# Keep real secrets out of git — .env is in .gitignore.

# ── Nostr ─────────────────────────────────────────────────────────────────────
# Required: your agent's Nostr private key (hex or nsec bech32)
METIQ_NOSTR_KEY=

# Required when auto-generating bootstrap.json: comma-separated relay URLs
#METIQ_NOSTR_RELAYS=wss://nos.lol,wss://relay.primal.net,wss://relay.nostr.band

# ── LLM providers (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#GEMINI_API_KEY=
#XAI_API_KEY=
#GROQ_API_KEY=
#MISTRAL_API_KEY=
#OPENROUTER_API_KEY=
#TOGETHER_API_KEY=

# Default model (optional — defaults to claude-sonnet-4-5)
#METIQ_DEFAULT_MODEL=claude-sonnet-4-5

# ── Build options ─────────────────────────────────────────────────────────────
# Uncomment to bake extras into the image at build time:
#METIQ_VERSION=dev
#METIQ_VARIANT=default
#METIQ_INSTALL_PYTHON=1
#METIQ_INSTALL_NODE=1
#METIQ_INSTALL_BROWSER=1
#METIQ_INSTALL_DOCKER_CLI=1
#METIQ_APT_PACKAGES=

# ── Browser sandbox ──────────────────────────────────────────────────────────
# Enable the playwright profile first: docker compose --profile browser up -d
#METIQ_BROWSER_URL=http://playwright:3500
#METIQ_BROWSER_TOKEN=

# ── Admin API ─────────────────────────────────────────────────────────────────
# The admin healthcheck endpoint is exposed on port 7423 by default.
# Override the admin listen address inside the container:
#METIQ_ADMIN_ADDR=0.0.0.0:7423

# ── Skills ───────────────────────────────────────────────────────────────────
# Bundled skills are baked into the image at /app/skills
# Managed (user-installed) skills live at /data/.metiq/skills
#METIQ_MANAGED_SKILLS_DIR=/data/.metiq/skills

# ── Podman (only used by setup-podman.sh / run-metiq-podman.sh) ──────────────
#METIQ_PODMAN_USER=metiq
#METIQ_PODMAN_IMAGE=metiqd:local
#METIQ_PODMAN_CONTAINER=metiqd
