# swarmstrd — Podman Quadlet (rootless)
# Installed by setup-podman.sh into ~/.config/containers/systemd/
# {{SWARMSTR_HOME}} is replaced at install time.

[Unit]
Description=swarmstrd (rootless Podman)

[Container]
Image=swarmstrd:local
ContainerName=swarmstrd
UserNS=keep-id
# Keep container UID/GID aligned with the invoking user so mounted config is readable.
User=%U:%G
Volume={{SWARMSTR_HOME}}/.swarmstr:/home/swarmstr/.swarmstr
EnvironmentFile={{SWARMSTR_HOME}}/.swarmstr/.env
Environment=HOME=/home/swarmstr
Environment=TERM=xterm-256color
Pull=never
Exec=/usr/local/bin/swarmstrd

[Service]
TimeoutStartSec=300
Restart=on-failure

[Install]
WantedBy=default.target
