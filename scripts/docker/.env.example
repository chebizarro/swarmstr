# ── Nostr ─────────────────────────────────────────────────────────────────────
# Required: your agent's Nostr private key (hex or nsec bech32)
SWARMSTR_NOSTR_KEY=

# Optional: comma-separated relay URLs (defaults to popular public relays)
#SWARMSTR_NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band

# ── LLM providers (at least one required) ────────────────────────────────────
ANTHROPIC_API_KEY=
#OPENAI_API_KEY=
#GEMINI_API_KEY=
#XAI_API_KEY=
#GROQ_API_KEY=
#MISTRAL_API_KEY=
#OPENROUTER_API_KEY=
#TOGETHER_API_KEY=

# Default model
SWARMSTR_DEFAULT_MODEL=claude-sonnet-4-5

# ── Browser sandbox ───────────────────────────────────────────────────────────
# Uncomment and enable the playwright service in docker-compose.yml first
#SWARMSTR_BROWSER_URL=http://playwright:3500

# ── Skills ───────────────────────────────────────────────────────────────────
# Bundled skills are baked into the image at /app/skills
# Managed (user-installed) skills live at /data/.swarmstr/skills
#SWARMSTR_MANAGED_SKILLS_DIR=/data/.swarmstr/skills
